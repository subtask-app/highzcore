# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Note: In Supabase Dashboard, these are labeled as:
# - Project URL → NEXT_PUBLIC_SUPABASE_URL
# - anon/public key → NEXT_PUBLIC_SUPABASE_ANON_KEY (also called NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY)
# - service_role key → SUPABASE_SERVICE_ROLE_KEY (keep this secret!)

# Google OAuth & YouTube API
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
YOUTUBE_API_KEY=your_youtube_api_key

# Cloudinary (for image/video uploads in messages)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name

# Email (Gmail via Supabase SMTP)
# Configure in Supabase Dashboard → Project Settings → Auth → SMTP Settings
# Use your Gmail address and app password

# App Config
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Highzcore

# Bank Account Details (for payment instructions)
BANK_ACCOUNT_NAME=Highzcore
BANK_ACCOUNT_NUMBER=0123456789
BANK_NAME=Example Bank
BANK_ACCOUNT_TYPE=Savings
