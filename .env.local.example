# ============================================================
# Supabase
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# In the Supabase Dashboard these appear as:
#   Project URL          → NEXT_PUBLIC_SUPABASE_URL
#   anon/public key      → NEXT_PUBLIC_SUPABASE_ANON_KEY
#   service_role key     → SUPABASE_SERVICE_ROLE_KEY   (keep secret!)

# ============================================================
# Google OAuth & YouTube
# ============================================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
YOUTUBE_API_KEY=your_youtube_api_key

# ============================================================
# Email (transactional) — nodemailer over Gmail SMTP
# ============================================================
# Reuse the same Gmail address + app password you set in Supabase Auth.
# Create an app password at: https://myaccount.google.com/apppasswords
# (You must have 2-Step Verification enabled on the account.)
GMAIL_USER=your.address@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx
# Optional display name override. Default is `"Highzcore" <GMAIL_USER>`.
FROM_EMAIL="Highzcore <noreply@yourdomain.com>"

# ============================================================
# Cron security — protects /api/cron/* endpoints
# ============================================================
# Use a long random string. The pg_cron job and any external cron must send
# this same value in the `X-Cron-Secret` header when calling the endpoints.
CRON_SECRET=replace_me_with_a_long_random_string

# ============================================================
# OAuth state signing — protects the YouTube-grant callback
# ============================================================
# Used to HMAC-sign the `state` parameter sent to Google during the YouTube
# access-grant flow, so the callback can't be replayed against another user.
# If unset, falls back to SUPABASE_SERVICE_ROLE_KEY.
OAUTH_STATE_SECRET=replace_me_with_a_long_random_string

# ============================================================
# Telegram (Mini App + bot)
# ============================================================
# Create the bot via @BotFather and grab its token.
TELEGRAM_BOT_TOKEN=
# The bot's @username (without the @). Used to build deep links.
TELEGRAM_BOT_USERNAME=HighzcoreBot
# Long random string. Used as the `secret_token` when calling setWebhook,
# and verified on every incoming /api/telegram/webhook request.
TELEGRAM_WEBHOOK_SECRET=replace_me_with_a_long_random_string
# Optional (M10): the @username (no @) of the public community channel the
# bot posts to when a contract is activated. Leave blank to disable channel
# broadcasts. See TELEGRAM_SETUP.md §7.
TELEGRAM_CHANNEL_USERNAME=
# Optional alternative to TELEGRAM_CHANNEL_USERNAME — use this for private
# channels (negative numeric chat id).
TELEGRAM_CHANNEL_CHAT_ID=
# Required for live support (M10): numeric chat id of the admin group the
# bot forwards user DMs into. Groups have NEGATIVE ids. See TELEGRAM_SETUP.md §6.
TELEGRAM_ADMIN_CHAT_ID=

# ============================================================
# Cloudinary (chat media)
# ============================================================
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name

# ============================================================
# App config
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Highzcore

# ============================================================
# Bank account (shown to clients as payment instructions)
# ============================================================
BANK_ACCOUNT_NAME=Highzcore
BANK_ACCOUNT_NUMBER=0123456789
BANK_NAME=Example Bank
BANK_ACCOUNT_TYPE=Savings

# ============================================================
# Support contact
# ============================================================
WHATSAPP_NUMBER=
